{{define "status_boxes"}}
{{/* 1. Setup local variables - Corrected field names */}}
{{$coin := "DGB"}}
{{if .CoinSymbol}}
    {{$coin = .CoinSymbol}}
{{else if .BrandName}}
    {{$coin = .BrandName}}
{{end}}

{{$fiat := "USD"}}
{{if .FiatCurrency}}{{$fiat = .FiatCurrency}}{{end}}

<div class="status-group">
<div class="text-sm status-group-title">Pool</div>
<div class="grid status-grid">
		<div class="card">
			<div class="label">Open connections</div>
			<div class="value">--</div>
		</div>
		<div class="card">
			<div class="label">Shares per minute</div>
			<div class="value">--</div>
		</div>
		<div class="card">
			<div class="label">Pool hashrate</div>
			<div class="value" id="status-pool-hashrate">--</div>
		</div>
	<div class="card">
		<div class="label">Annual block odds</div>
		<div class="value mono" id="status-block-chance">--</div>
	</div>
	<div class="card">
		<div class="label">Time left for block</div>
		<div class="value mono" id="status-block-time-left">--</div>
		<div class="card-context" id="status-block-history">--</div>
	</div>
	<div class="card">
		<div class="label">TRANSACTIONS REWARDS</div>
		<div class="value mono" id="status-template-tx-fees">--</div>
	</div>
	<div class="card">
		<div class="label">Pool tag</div>
		<div class="value mono" id="status-pool-tag">--</div>
	</div>
	<div class="card">
		<div class="label">Pool fee</div>
		{{if gt .PoolFeePercent 0.0}}
			<div class="value">
				{{printf "%.2f" .PoolFeePercent}}%
			</div>
			{{if gt .OperatorDonationPercent 0.0}}
				<div class="card-context">Split coinbase, pays directly to miner<br>
				<span style="opacity: 0.8;">{{printf "%.1f" .OperatorDonationPercent}}% of pool fee donated{{if .OperatorDonationName}} to {{if .OperatorDonationURL}}<a href="{{.OperatorDonationURL}}" target="_blank" rel="noopener noreferrer" style="color:inherit;text-decoration:underline;">{{.OperatorDonationName}}</a>{{else}}{{.OperatorDonationName}}{{end}}{{end}}</span><br>
				</div>
			{{else}}
				<div class="card-context">Split coinbase, pays directly to miner<br>
				</div>
			{{end}}
		{{else}}
			<div class="value">None</div>
			<div class="card-context">No fee charged</div>
		{{end}}
	</div>
</div>
</div>

<div class="status-group">
<div class="text-sm status-group-title">NETWORK</div>
<div class="grid status-grid">
	<div class="card">
		<div class="label">Network HASHRATE</div>
		<div class="value mono" id="status-network-hashrate">--</div>
	</div>
	<div class="card">
		<div class="label">Network difficulty</div>
		<div class="value mono" id="status-block-difficulty">--</div>
	</div>
	<div class="card">
		<div class="label">Block height</div>
		<div class="value mono" id="status-block-height">--</div>
	</div>
	<div class="card">
	    <div class="label">{{.CoinSymbol}} PRICE</div>
	    <div class="value mono" id="status-btc-price">
        	{{if gt .BTCPriceFiat 0.0}}
	            {{.CoinSymbol}} ${{printf "%.4f" .BTCPriceFiat}} {{.FiatCurrency}}
        	{{else}}
	            --
	        {{end}}
	    </div>
    </div>
</div>
</div>

{{/* 2. THE SHIELD SCRIPT: Runs inside the template but only if not BTC */}}
{{if ne $coin "BTC"}}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const coin = "{{$coin}}";
        const fiat = "{{.FiatCurrency}}".toUpperCase() || "USD";

        const fixAltcoinUI = () => {
            // Fetch High-Precision Price from CoinGecko
            fetch(`https://api.coingecko.com{fiat.toLowerCase()}`)
                .then(res => res.json())
                .then(data => {
                    const price = data.digibyte[fiat.toLowerCase()];
                    const priceBox = document.getElementById('status-btc-price');
                    if (priceBox && price) {
                        priceBox.innerText = `${coin} $${price.toFixed(4)} ${fiat}`;
                    }
                });

            // Replace any "BTC" labels that the backend refresh might inject
            document.querySelectorAll('.card .label, .card .value').forEach(el => {
                if (el.innerHTML.includes("BTC")) {
                    el.innerHTML = el.innerHTML.replace(/BTC/g, coin);
                }
            });
        };

        // Watch for updates and immediately fix
        new MutationObserver(fixAltcoinUI).observe(document.body, { childList: true, subtree: true });
        fixAltcoinUI();
    });
</script>
{{end}}
{{end}}

